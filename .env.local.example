# ─── Copy this file to .env.local and fill in every value ──────────────────────
# Never commit .env.local to git

# Database — from: terraform output cosmos_connection_string
MONGODB_URI=

# NextAuth — generate secret with: openssl rand -base64 32
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=

# Admin login credentials
ADMIN_EMAIL=constelladora@ecosyalmas.com
ADMIN_PASSWORD_HASH=   # generate with: node -e "require('bcryptjs').hash('YOUR_PASS',12).then(console.log)"

# Azure Blob Storage — from: terraform output storage_connection_string
AZURE_STORAGE_CONNECTION_STRING=
AZURE_STORAGE_CONTAINER=photos

# Stripe — from: https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY=sk_test_
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_
STRIPE_WEBHOOK_SECRET=whsec_    # from Stripe Dashboard > Webhooks

# Email — from: Azure Communication Services SMTP setup
SMTP_HOST=smtp.azurecomm.net
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=DoNotReply@xxxxxxxx.azurecomm.net
ADMIN_EMAIL_NOTIFY=constelladora@ecosyalmas.com

# Session price in cents (e.g. 5000 = $50.00)
SESSION_PRICE=5000
